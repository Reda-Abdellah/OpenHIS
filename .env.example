# ⚠️  SECURITY: All values marked CHANGE_ME_BEFORE_DEPLOY MUST be changed
# before running this stack in any environment. Never commit real credentials.
#
# Copy this file to .env and fill in all values before starting the stack.
# docker compose automatically loads .env from the project root.

# ── Deployment profiles ───────────────────────────────────────────────────────
# Comma-separated list of profiles to activate.
# Available: emr, laboratory, erp, imaging, analytics, legacy
# Default (if unset): all profiles (full stack)
#
# Examples:
#   OPENHIS_PROFILES=imaging               # Imaging suite only
#   OPENHIS_PROFILES=emr,laboratory        # EMR + Lab (no imaging/ERP)
#   OPENHIS_PROFILES=emr,laboratory,erp,imaging,analytics  # Full stack
#
OPENHIS_PROFILES=emr,laboratory,erp,imaging,analytics

# ── PostgreSQL (shared — Orthanc, MPI) ───────────────────────────────────────
POSTGRES_USER=openhis
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
MPI_DB_PASS=CHANGE_ME_BEFORE_DEPLOY
# Duplicate-flag threshold for the MPI matcher (default 0.75; see T-16).
#MPI_MATCH_THRESHOLD=0.75
# Identifier system URI advertised by the MPI FHIR facade (PDQm/PIXm)
#MPI_FHIR_SYSTEM=urn:openhis:mpi:mrn

# ── Redis event bus (base — always on) ───────────────────────────────────────
# Password for Redis AUTH. Empty (the default when unset) keeps auth DISABLED
# so the dev stack works out of the box. Setting it here is sufficient: the
# redis server gets --requirepass and every service's REDIS_URL embeds it.
REDIS_PASSWORD=

# ── Keycloak ──────────────────────────────────────────────────────────────────
# Admin console credentials (initial bootstrap only)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# openhis-platform client — used by admin service and as audience for JWT validation
# Must match infra/keycloak/openhis-realm.json → clients[openhis-platform].secret
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_BEFORE_DEPLOY

# Public URL of Keycloak — must be reachable from browsers (not the internal container name)
# Example: https://auth.yourhospital.org  or  http://localhost:8080 in dev
KEYCLOAK_PUBLIC_URL=http://localhost/keycloak

# Admin SPA public OIDC client (no secret — public PKCE client)
# Must match infra/keycloak/openhis-realm.json → clients[openhis-admin-spa].clientId
KEYCLOAK_SPA_CLIENT_ID=openhis-admin-spa

# JWKS endpoint the nginx njs guard uses to verify JWT signatures (RS256).
# Keycloak serves under the /keycloak relative path (KC_HTTP_RELATIVE_PATH) —
# keep that path segment if you point this at an external Keycloak.
KEYCLOAK_JWKS_URL=http://keycloak:8080/keycloak/realms/openhis/protocol/openid-connect/certs

# ── Service account credentials (one per native service) ─────────────────────
# Each service uses client_credentials to obtain tokens from Keycloak.
# Must match infra/keycloak/openhis-realm.json → clients[*-sa].secret

# Integration Hub service account
INTEGRATION_HUB_KC_TOKEN_URL=http://keycloak:8080/keycloak/realms/openhis/protocol/openid-connect/token
INTEGRATION_HUB_KC_CLIENT_ID=integration-hub-sa
INTEGRATION_HUB_KC_CLIENT_SECRET=CHANGE_ME_BEFORE_DEPLOY

# HL7 Gateway service account
HL7_KC_TOKEN_URL=http://keycloak:8080/keycloak/realms/openhis/protocol/openid-connect/token
HL7_KC_CLIENT_ID=hl7-sa
HL7_KC_CLIENT_SECRET=CHANGE_ME_BEFORE_DEPLOY

# Analytics service account
ANALYTICS_KC_TOKEN_URL=http://keycloak:8080/keycloak/realms/openhis/protocol/openid-connect/token
ANALYTICS_KC_CLIENT_ID=analytics-sa
ANALYTICS_KC_CLIENT_SECRET=CHANGE_ME_BEFORE_DEPLOY

# RIS service account
RIS_KC_TOKEN_URL=http://keycloak:8080/keycloak/realms/openhis/protocol/openid-connect/token
RIS_KC_CLIENT_ID=ris-sa
RIS_KC_CLIENT_SECRET=CHANGE_ME_BEFORE_DEPLOY

# Patient Portal service account
PATIENT_PORTAL_KC_TOKEN_URL=http://keycloak:8080/keycloak/realms/openhis/protocol/openid-connect/token
PATIENT_PORTAL_KC_CLIENT_ID=patient-portal-sa
PATIENT_PORTAL_KC_CLIENT_SECRET=CHANGE_ME_BEFORE_DEPLOY

# Orthanc plugin service account (imaging profile) — bearer token for the
# ai-controller trigger and hub dicom-stored event POSTs
ORTHANC_KC_TOKEN_URL=http://keycloak:8080/keycloak/realms/openhis/protocol/openid-connect/token
ORTHANC_KC_CLIENT_ID=orthanc-sa
ORTHANC_KC_CLIENT_SECRET=CHANGE_ME_BEFORE_DEPLOY

# ── EMR profile (OpenMRS) ────────────────────────────────────────────────────
# All EMR secrets have compose-level dev defaults — if a variable is unset,
# the historical dev value applies and the stack starts unchanged.
# Uncomment and set before any real deployment.
#
# MySQL root password (openmrs-db) — dev default: openmrs_root
#OPENMRS_DB_ROOT_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
# MySQL application password (openmrs-db MYSQL_PASSWORD + OpenMRS
# OMRS_DB_PASSWORD — one var keeps both sides in sync) — dev default: openmrs
#OPENMRS_DB_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
# OpenMRS admin user — drives OMRS_ADMIN_USER_PASSWORD (emr profile) and the
# integration-hub Basic-auth adapter — dev defaults: admin / Admin123
#OPENMRS_USER=admin
#OPENMRS_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
# OpenMRS Keycloak OIDC client secret — rendered into
# infra/keycloak/openhis-realm.json by `opm render-infra` (set by `opm init`)
OPENMRS_KC_CLIENT_SECRET=CHANGE_ME_BEFORE_DEPLOY

# ── Laboratory profile (OpenELIS) ────────────────────────────────────────────
# OpenELIS Global 2's HAPI FHIR endpoint requires HTTP Basic auth — it does
# not accept Keycloak bearer tokens. The integration-hub adapter uses these
# credentials for FHIR reads/writes, and the same OPENELIS_PASSWORD seeds
# the OE admin account (DEFAULT_PW).
OPENELIS_USER=admin
OPENELIS_PASSWORD=adminADMIN!
# OpenELIS Keycloak OIDC client secret — rendered into
# infra/keycloak/openhis-realm.json by `opm render-infra` (set by `opm init`)
OPENELIS_OIDC_SECRET=CHANGE_ME_BEFORE_DEPLOY
#
# The following have compose-level dev defaults — if unset, the historical
# dev value applies. Uncomment and set before any real deployment.
#
# openelis-db postgres superuser password — dev default: postgres
#OPENELIS_PG_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
# clinlims application DB password (openelis-db DB_PASSWORD + OE datasource
# password — one var keeps both sides in sync) — dev default: clinlims
#OPENELIS_DB_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
# clinlims superuser password — dev default: clinlims_super
#OPENELIS_DB_SUPERUSER_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
# OpenELIS's backing FHIR store (oe-fhir-store HAPI container) — the hub reads
# lab results here; only override for an external/persistent HAPI deployment.
#OPENELIS_FHIR_STORE_URL=http://oe-fhir-store:8080/fhir

# ── ERP profile (Odoo) ───────────────────────────────────────────────────────
ODOO_DB=odoo
# PostgreSQL password shared by odoo-db (POSTGRES_PASSWORD) and the odoo app
# server (PASSWORD env) — one var keeps both sides in sync. Compose-level dev
# default applies if unset: odoo. Uncomment and set before any real deployment.
# Note: db_password was removed from infra/odoo/odoo.conf so this env var is
# authoritative (the official odoo image prefers odoo.conf over env).
#ODOO_DB_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
# Master password (admin_passwd in odoo.conf) — used only for DB management
ODOO_MASTER_PASS=CHANGE_ME_BEFORE_DEPLOY
# Admin user password — used by setup_oidc.py and integration-hub XML-RPC calls
ODOO_ADMIN_PASS=CHANGE_ME_BEFORE_DEPLOY
ODOO_LANG=en_US
# Must match infra/keycloak/openhis-realm.json → clients[odoo-oidc].secret
ODOO_OIDC_SECRET=CHANGE_ME_BEFORE_DEPLOY

# ── Imaging profile (AI pipeline container hardening) ───────────────────────
# Comma-separated docker images the AI runner may spawn as pipeline containers.
# Extend it to run the seeded clinical pipelines (poc-lab-risk, poc-emr-alert).
POC_ALLOWED_IMAGES=openhis/poc-xray:latest,openhis/poc-ct:latest
# Hard memory cap per pipeline container (memswap pinned to same value = no swap)
POC_MEM_LIMIT=2g
# CPU cores per pipeline container (float, converted to nano_cpus)
POC_CPU_LIMIT=2
# Max processes per pipeline container
POC_PIDS_LIMIT=256


# ── Development mode ──────────────────────────────────────────────────────────
# Set DEV_MODE=true to disable JWT validation on all native services.
# A loud startup warning is logged. DEV_MODE=true is ONLY allowed when
# ENV=development — any other ENV value makes services exit(1) at startup.
#
# WARNING: Never set DEV_MODE=true in production.
DEV_MODE=false
ENV=development

# ── Analytics collection interval ────────────────────────────────────────────
COLLECT_INTERVAL_MIN=5

# ── Data retention & privacy ─────────────────────────────────────────────────
# Minimum years patient data must be retained before archival/deletion.
# Regulatory defaults: HIPAA = 6, GDPR/EU = varies (typically 10 for medical).
# Set to 0 to disable time-based archival.
PATIENT_DATA_RETENTION_YEARS=6
AUDIT_RETENTION_DAYS=90

# ── MLLP HL7 listener ────────────────────────────────────────────────────────
# Maximum bytes buffered per connection before it is dropped (default 1 MB).
MLLP_MAX_MSG_BYTES=1048576
# The MLLP port (2575) is INTERNAL-ONLY by default: feeders inside the Docker
# network reach it at hl7:2575; external feeders should use a VPN/SSH tunnel
# or a TLS proxy (stunnel). MLLP is cleartext HL7 v2 carrying PHI — to publish
# the host port deliberately (firewalled/TLS-fronted environments only), run:
#   docker compose -f compose/base.yml -f compose/overrides/mllp-public.yml up -d hl7

# ── Backups ──────────────────────────────────────────────────────────────────
# Output directory for scripts/backup.sh (each run creates a timestamped
# subdirectory with a manifest.json + SHA256SUMS). Gitignored.
#BACKUP_DIR=./backups

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_FORMAT=json  (default) for structured JSON output (use with log aggregators)
# LOG_FORMAT=text  for human-readable output during local development
LOG_LEVEL=INFO
LOG_FORMAT=json
