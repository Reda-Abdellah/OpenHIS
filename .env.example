# Copy this file to .env and fill in the values.
# docker compose automatically loads .env from the project root.

# ── PostgreSQL (shared by Orthanc and HAPI FHIR) ─────────────────────────────
POSTGRES_DB=orthanc
POSTGRES_USER=orthanc
POSTGRES_PASSWORD=changeme

# ── Admin dashboard ───────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=changeme

# ── Session expiry ────────────────────────────────────────────────────────────
SESSION_TTL_HOURS_ADMIN=12
SESSION_TTL_HOURS_PORTAL=24

# ── FHIR server (optional — only used with --profile fhir) ───────────────────
# Leave empty to disable FHIR push from fhir-bridge:
FHIR_SERVER_URL=http://fhir-server:8080/fhir
FHIR_ENABLED=true

# ── Analytics collection interval ────────────────────────────────────────────
COLLECT_INTERVAL_MIN=5
