{
  "name": "mpi",
  "display_name": "Master Patient Index",
  "port": 8007,
  "profile": "base",
  "nginx_path": "/mpi/",
  "health_path": "/api/health",
  "bus": {
    "publishes": ["patient.synced"],
    "subscribes": ["patient.registered"]
  },
  "depends_on": ["redis", "postgres"],
  "env": {
    "required": [
      "KEYCLOAK_URL",
      "REDIS_URL",
      "MPI_DATABASE_URL"
    ]
  },
  "description": "Cross-reference registry linking patient identities across all connected systems."
}
