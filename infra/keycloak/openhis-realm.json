{
  "realm": "openhis",
  "enabled": true,
  "displayName": "OpenHIS Platform",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Platform administrator"
      },
      {
        "name": "clinician",
        "description": "Clinical staff (physician, nurse)"
      },
      {
        "name": "radiologist",
        "description": "Radiology staff"
      },
      {
        "name": "lab-tech",
        "description": "Laboratory technician"
      },
      {
        "name": "pharmacist",
        "description": "Pharmacy staff"
      },
      {
        "name": "patient",
        "description": "Patient self-service access"
      }
    ]
  },
  "clients": [
    {
      "clientId": "openhis-platform",
      "name": "OpenHIS Platform Services",
      "description": "Confidential OIDC client for backend service accounts (admin, integration-hub, etc.)",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "secret": "openhis-platform-secret",
      "redirectUris": [],
      "webOrigins": [],
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "odoo-oidc",
      "name": "Odoo ERP (OAuth2 SSO)",
      "description": "Confidential OIDC client for Odoo 17 auth_oauth module \u2014 server-side code exchange",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "secret": "odoo-oidc-secret",
      "redirectUris": [
        "http://localhost/web/auth_oauth/signin"
      ],
      "webOrigins": [
        "http://localhost"
      ],
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "openhis-spa",
      "name": "OpenHIS Portal (SPA)",
      "description": "Public OIDC client for the browser portal \u2014 no secret, uses PKCE",
      "enabled": true,
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost/*"
      ],
      "webOrigins": [
        "http://localhost"
      ],
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@openhis.local",
      "firstName": "Platform",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ],
      "clientRoles": {
        "realm-management": [
          "realm-admin",
          "manage-users",
          "manage-clients",
          "manage-realm",
          "view-users",
          "view-clients",
          "view-realm"
        ]
      }
    }
  ],
  "accessTokenLifespan": 300,
  "refreshTokenMaxReuse": 0,
  "ssoSessionMaxLifespan": 36000
}