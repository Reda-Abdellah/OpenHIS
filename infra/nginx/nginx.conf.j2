# njs module — powers the JWT auth_request guards in infra/nginx/njs/jwt-auth.js
load_module modules/ngx_http_js_module.so;

# Expose the JWKS endpoint override to njs (process.env); defaults to the
# in-network Keycloak realm certs URL when unset.
env KEYCLOAK_JWKS_URL;

events {
    worker_connections 1024;
}

http {
    resolver 127.0.0.11 valid=10s ipv6=off;

    js_import jwt from njs/jwt-auth.js;
    js_fetch_timeout 5s;

    # ── Base service upstreams (always-on) ─────────────────────────────────────
    upstream admin_be      { server admin:8011; }
    upstream mpi_be        { server mpi:8007; }
    upstream keycloak_be   { server keycloak:8080; }
    upstream hub_be        { server integration-hub:8012; }
    upstream hl7_be        { server hl7:8009; }

{% if 'emr' in active_profiles %}
    # ── EMR profile upstreams ───────────────────────────────────────────────────
    upstream openmrs_be    { server openmrs:8080; }
    upstream openmrs_fe    { server openmrs-frontend:80; }
{% endif %}

{% if 'laboratory' in active_profiles %}
    # ── Laboratory profile upstreams ────────────────────────────────────────────
    upstream openelis_be    { server openelis:8080; }
{% endif %}

{% if 'erp' in active_profiles %}
    # ── ERP profile upstreams ───────────────────────────────────────────────────
    upstream odoo_be       { server odoo:8069; }
{% endif %}

{% if 'imaging' in active_profiles %}
    # ── Imaging profile upstreams ───────────────────────────────────────────────
    upstream orthanc       { server orthanc:8042; }
    upstream ohif          { server ohif:80; }
    upstream ris           { server ris:8002; }
    upstream aicontroller  { server ai-controller:8000; }
    upstream simulator     { server simulator:8001; }
{% endif %}

{% if 'analytics' in active_profiles %}
    # ── Analytics profile upstreams ─────────────────────────────────────────────
    upstream analytics     { server analytics:8008; }
    upstream patientportal { server patient-portal:8010; }
{% endif %}

{% for route in extra_upstreams %}
    upstream {{ route.name }} { server {{ route.addr }}; }
{% endfor %}

    server {
        listen 80;
        root /usr/share/nginx/html;

        # ── Internal JWT guards (njs, RS256-verified against Keycloak JWKS) ────
        # Mapped to jwt-auth.js; used as auth_request gates by locations whose
        # upstream has no authentication of its own (e.g. Orthanc).
        location = /_auth/admin       { internal; js_content jwt.require_admin; }
        location = /_auth/clinician   { internal; js_content jwt.require_clinician; }
        location = /_auth/lab_tech    { internal; js_content jwt.require_lab_tech; }
        location = /_auth/radiologist { internal; js_content jwt.require_radiologist; }
        location = /_auth/pharmacist  { internal; js_content jwt.require_pharmacist; }
        location = /_auth/patient     { internal; js_content jwt.require_patient; }
        location = /_auth/any         { internal; js_content jwt.require_any_auth; }

        # ── Prometheus /metrics — internal scrape only ──────────────────────────
        # Service /metrics endpoints (openhis_sdk.metrics) are JWT-exempt so
        # the in-network scraper needs no token. Without this guard the
        # service prefix locations below (/mpi/, /admin/, …) would expose
        # /<svc>/metrics publicly. Regex locations win over prefix matches,
        # so this 404s them all. Scrape directly: http://<svc>:<port>/metrics.
        location ~ ^/[a-z0-9_-]+/metrics/?$ { return 404; }

        # ── Portal entry point ──────────────────────────────────────────────────
        location / {
            try_files $uri $uri/ @fallback;
        }

        location @fallback {
            rewrite ^.*$ /index.html last;
        }

        # ── Base services (always available) ───────────────────────────────────
        location /admin/ {
            proxy_pass         http://admin_be/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Prefix /admin;
        }

        location /mpi/ {
            proxy_pass         http://mpi_be/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Prefix /mpi;
        }

        location /keycloak/ {
            proxy_pass         http://keycloak_be/keycloak/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Host   $host;
            proxy_set_header   X-Forwarded-Port   80;
            proxy_read_timeout 300s;
        }

        location /integration-hub/ {
            proxy_pass         http://hub_be/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
        }

        location /hl7/ {
            proxy_pass         http://hl7_be/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Prefix /hl7;
        }

{% if 'emr' in active_profiles %}
        # ── EMR: OpenMRS O3 ────────────────────────────────────────────────────
        # Login-start: clears any stale JSESSIONID before initiating OAuth2 flow.
        # Prevents redirect loops when a non-oauth2 session cookie is present.
        location = /openmrs/login-start {
            add_header Set-Cookie "JSESSIONID=; Path=/openmrs; HttpOnly; Max-Age=0" always;
            return 302 /openmrs/oauth2login;
        }

        # SPA must come BEFORE the general /openmrs/ block.
        location /openmrs/spa/ {
            proxy_pass         http://openmrs_fe/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_http_version 1.1;
            proxy_set_header   Upgrade            $http_upgrade;
            proxy_set_header   Connection         "upgrade";
        }

        location /openmrs/ {
            proxy_pass         http://openmrs_be/openmrs/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Host   $host;
            proxy_set_header   X-Forwarded-Port   80;
            proxy_read_timeout 300s;
        }
{% endif %}

{% if 'laboratory' in active_profiles %}
        # ── Laboratory: OpenELIS Global 2 ──────────────────────────────────────
        location /OpenELIS-Global/ {
            proxy_pass         http://openelis_be/OpenELIS-Global/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_redirect     https://$host/ http://$host/;
            proxy_hide_header  Strict-Transport-Security;
            proxy_read_timeout 300s;
        }

        location /openelis-fhir/ {
            # Machine-to-machine FHIR route — no JWT (OpenELIS subscriber has
            # no token). Restricted to the pinned openhis-net Docker subnet.
            allow 172.28.0.0/16;
            deny  all;
            proxy_pass         http://openelis_be/fhir/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_read_timeout 300s;
        }

{% endif %}

{% if 'erp' in active_profiles %}
        # ── ERP: Odoo 17 ───────────────────────────────────────────────────────
        location /auth_oauth/ {
            proxy_pass         http://odoo_be;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Host   $host;
            proxy_read_timeout 300s;
        }

        location /longpolling/ {
            proxy_pass         http://odoo_be;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_http_version 1.1;
            proxy_set_header   Upgrade            $http_upgrade;
            proxy_set_header   Connection         "upgrade";
        }

        location /web {
            proxy_pass         http://odoo_be;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Host   $host;
            proxy_read_timeout 300s;
        }


        location /odoo/longpolling/ {
            proxy_pass         http://odoo_be/longpolling/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_http_version 1.1;
            proxy_set_header   Upgrade            $http_upgrade;
            proxy_set_header   Connection         "upgrade";
        }


        location /odoo/ {
            proxy_pass         http://odoo_be/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Host   $host;
            proxy_redirect     ~^(https?://[^/]+)/(?!odoo/)(.*)$ $1/odoo/$2;
            proxy_read_timeout 300s;
        }
{% endif %}

{% if 'imaging' in active_profiles %}
        # ── Imaging: Orthanc + OHIF + RIS + AI ─────────────────────────────────
        location ~ ^/(app-config\.js|init-service-worker\.js|app\.bundle.*|assets/|[0-9]+\.bundle\..*|[0-9]+\.css)$ {
            proxy_pass http://ohif;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        location /ohif/ {
            proxy_pass         http://ohif/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Prefix /ohif;
        }

        location /orthanc/ {
            # Orthanc itself has AuthenticationEnabled=false in dev: this
            # gate is the ONLY auth layer in front of the DICOM store.
            auth_request       /_auth/radiologist;
            # NB: $remote_user is an nginx built-in (Basic auth) — a custom
            # name is required or nginx fails with "duplicate variable".
            auth_request_set   $auth_user  $sent_http_x_remote_user;
            auth_request_set   $auth_roles $sent_http_x_remote_roles;
            proxy_set_header   X-Remote-User  $auth_user;
            proxy_set_header   X-Remote-Roles $auth_roles;
            proxy_pass         http://orthanc/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Prefix /orthanc;
        }

        location /ris/ {
            proxy_pass         http://ris/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Prefix /ris;
        }

        location /ai-controller/ {
            proxy_pass         http://aicontroller/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Prefix /ai-controller;
        }

        location /simulator/ {
            proxy_pass         http://simulator/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Prefix /simulator;
        }
{% endif %}

{% if 'analytics' in active_profiles %}
        # ── Analytics: collector + patient portal ───────────────────────────────
        location /analytics/ {
            proxy_pass         http://analytics/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Prefix /analytics;
        }

        location /patient-portal/ {
            proxy_pass         http://patientportal/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Prefix /patient-portal;
        }
{% endif %}

{% for route in extra_routes %}
        # ── {{ route.label }} ──
        location {{ route.path }} {
            proxy_pass         http://{{ route.name }}/;
            proxy_set_header   Host               $host;
            proxy_set_header   X-Real-IP          $remote_addr;
            proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto  $scheme;
            proxy_set_header   X-Forwarded-Prefix {{ route.path.rstrip('/') }};
        }
{% endfor %}
    }
}
